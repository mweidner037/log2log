{
  "name": "log2log",
  "version": "0.2.0",
  "description": "Convert a log of mutations into a log of key-value store changes",
  "author": "Matthew Weidner",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/mweidner037/log2log/issues"
  },
  "homepage": "https://github.com/mweidner037/log2log#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mweidner037/log2log.git"
  },
  "keywords": [
    "event sourcing",
    "mutations",
    "server reconciliation"
  ],
  "main": "build/commonjs/index.js",
  "browser": "build/esm/index.js",
  "module": "build/esm/index.js",
  "types": "build/esm/index.d.ts",
  "files": [
    "/build",
    "/src"
  ],
  "directories": {
    "lib": "src"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "packageManager": "pnpm@11.7.0",
  "dependencies": {
    "@types/functional-red-black-tree": "^1.0.6",
    "articulated": "^1.3.1",
    "functional-red-black-tree": "^1.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@istanbuljs/nyc-config-typescript": "^1.0.2",
    "@types/chai": "^4.3.4",
    "@types/mocha": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^7.7.1",
    "@typescript-eslint/parser": "^7.7.1",
    "chai": "^4.3.7",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "mocha": "^10.2.0",
    "nyc": "^15.1.0",
    "prettier": "^2.8.4",
    "tsx": "^4.22.4",
    "typedoc": "^0.25.13",
    "typescript": "^5.4.5"
  },
  "scripts": {
    "prepack": "pnpm run clean && pnpm run lint && pnpm run build && pnpm run test",
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.commonjs.json",
    "lint": "pnpm run \"/^lint:.*/\"",
    "lint:tsc": "tsc -p tsconfig.json --noEmit",
    "lint:tsc_test": "tsc -p test/tsconfig.json",
    "lint:eslint": "eslint .",
    "lint:prettier": "prettier . --check",
    "format": "prettier . --write",
    "test": "TSX_TSCONFIG_PATH=test/tsconfig.json mocha",
    "coverage": "pnpm run \"/^coverage:.*/\"",
    "coverage:run": "nyc pnpm run test",
    "coverage:open": "open coverage/index.html > /dev/null 2>&1 &",
    "docs": "typedoc --options typedoc.json src/index.ts",
    "clean": "rm -rf build docs coverage .nyc_output"
  }
}
